# .clang-tidy
# Clang-Tidy configuration for tv_studio educational project.
---
Checks: >
  -*,
  bugprone-*,
  clang-analyzer-*,
  modernize-*,
  performance-*,
  readability-*,
  -readability-implicit-bool-conversion,
  -modernize-use-nodiscard,
  -readability-isolate-declaration,
  -bugprone-exception-escape,
  -bugprone-empty-catch,
  -modernize-avoid-bind,
  -readability-convert-member-functions-to-static,
  -readability-identifier-length

# Treat all warnings as errors in CI to enforce clean code.
WarningsAsErrors: "*"

# Match all headers inside the src/ directory (supporting absolute paths)
HeaderFilterRegex: '.*/src/.*'

# Format configuration.
FormatStyle: none
...
